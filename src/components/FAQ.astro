---
interface Props {
  items: Array<{ q: string; a: string }>;
}

const { items } = Astro.props;
---

<div class="space-y-3">
  {items.map((item) => (
    <details class="group border border-border/60 rounded-lg overflow-hidden">
      <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer font-heading text-base text-foreground/90 select-none list-none [&::-webkit-details-marker]:hidden">
        <span>{item.q}</span>
        <svg
          class="w-4 h-4 shrink-0 text-muted-foreground/40 transition-transform duration-200 group-open:rotate-45"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
      </summary>
      <div class="px-6 pb-6 pt-0">
        <p class="text-muted-foreground font-body text-sm leading-relaxed">{item.a}</p>
      </div>
    </details>
  ))}
</div>

<style>
  details[open] > summary {
    border-bottom: 1px solid rgba(var(--border), 0.3);
    padding-bottom: 1.25rem;
    margin-bottom: 0;
  }

  details > div {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
  }

  details[open] > div {
    grid-template-rows: 1fr;
  }

  details > div > p {
    overflow: hidden;
  }
</style>
