---
import { Image } from 'astro:assets';
import sanghamLogo from '../assets/sangham-logo.png';
---

<footer class="border-t border-nav-foreground/10 bg-nav">
  <div class="container mx-auto px-6 py-16">
    <div class="flex flex-col items-center gap-8">
      <Image src={sanghamLogo} alt="Sangham" class="h-14 w-auto opacity-50" widths={[112, 224]} />

      <div class="divider-gold w-48"></div>

      <nav class="flex flex-wrap justify-center gap-6 text-sm text-nav-foreground/50" aria-label="Footer">
        <a href="/counselling" class="hover:text-gold-light transition-colors">Counselling</a>
        <a href="/practices" class="hover:text-gold-light transition-colors">Practices</a>
        <a href="/about" class="hover:text-gold-light transition-colors">About</a>
        <a href="/workshops" class="hover:text-gold-light transition-colors">Workshops</a>
        <a href="/wisdom" class="hover:text-gold-light transition-colors">Wisdom</a>
        <a href="/contact" class="hover:text-gold-light transition-colors">Contact</a>
        <a href="/scope" class="hover:text-gold-light transition-colors">Scope & Ethics</a>
        <a href="/privacy" class="hover:text-gold-light transition-colors">Privacy</a>
      </nav>

      <!-- Contact Details -->
      <div class="flex flex-wrap justify-center gap-6 text-sm text-nav-foreground/40">
        <a
          href="mailto:ramarishi@sangham.org"
          class="flex items-center gap-2 hover:text-gold-light transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          ramarishi@sangham.org
        </a>
        <a
          href="https://wa.me/27736738063"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 hover:text-gold-light transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          073 673 8063
        </a>
        <a
          href="https://instagram.com/sangham.space"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 hover:text-gold-light transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
          </svg>
          @Sangham.Space
        </a>
      </div>

      <p class="text-xs text-nav-foreground/30">
        Online sessions available worldwide.
      </p>
      <p class="text-xs text-nav-foreground/30">
        &copy; {new Date().getFullYear()} Sangham. All rights reserved.
      </p>
    </div>
  </div>
</footer>
