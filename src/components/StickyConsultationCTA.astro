<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-40 translate-y-full transition-transform duration-500 ease-out"
  role="complementary"
  aria-label="Consultation prompt"
>
  <div class="bg-nav/95 backdrop-blur-md border-t border-nav-foreground/10">
    <div class="container mx-auto px-6 py-3 flex items-center justify-between max-w-4xl">
      <a
        href="/contact"
        class="text-sm font-body text-nav-foreground/70 hover:text-gold-light transition-colors"
      >
        Ready to begin? Book an initial consultation &rarr;
      </a>
      <button
        id="sticky-cta-dismiss"
        class="text-nav-foreground/40 hover:text-nav-foreground/70 transition-colors p-1"
        aria-label="Dismiss consultation prompt"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  const cta = document.getElementById('sticky-cta');
  const dismiss = document.getElementById('sticky-cta-dismiss');

  if (cta && !sessionStorage.getItem('sticky-cta-dismissed')) {
    const observer = new IntersectionObserver(
      (entries) => {
        // Show when user has scrolled past 60% of the page
      },
      { threshold: 0 }
    );

    let shown = false;
    window.addEventListener('scroll', () => {
      if (shown) return;
      const scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      if (scrollPercent > 0.6) {
        shown = true;
        cta.classList.remove('translate-y-full');
        cta.classList.add('translate-y-0');
      }
    });

    dismiss?.addEventListener('click', () => {
      cta.classList.remove('translate-y-0');
      cta.classList.add('translate-y-full');
      sessionStorage.setItem('sticky-cta-dismissed', 'true');
    });
  }
</script>
