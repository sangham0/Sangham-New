---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { essays } from '../../data/essays';
import { practiceGuides } from '../../data/practice-guides';

export function getStaticPaths() {
  const allEssays = [...essays, ...practiceGuides];
  return allEssays.map((essay) => ({
    params: { id: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;

const wordCount = essay.paragraphs.join(' ').split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: essay.title,
    description: essay.paragraphs[0],
    datePublished: essay.datePublished,
    author: {
      '@type': 'Person',
      name: 'Michael Kaplan',
      alternateName: 'Swami Ramarishi',
    },
    publisher: { '@type': 'Organization', name: 'Sangham', url: 'https://sangham.org' },
  },
];
---

<BaseLayout
  title={essay.title}
  description={essay.excerpt}
  type="article"
  publishedDate={essay.datePublished}
  jsonLd={jsonLd}
>

  <!-- ESSAY HEADER -->
  <section class="bg-header py-20 md:py-28">
    <div class="container mx-auto px-6 max-w-3xl">
      <a
        href="/wisdom"
        class="inline-flex items-center gap-2 text-sm text-header-foreground/50 hover:text-header-foreground/80 font-body transition-colors mb-10"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Wisdom
      </a>

      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-gold-gradient mb-4">
        {essay.title}
      </h1>
      <div class="flex items-center gap-3 text-sm text-header-foreground/40 font-body">
        <span>{essay.dateLabel}</span>
        <span class="text-header-foreground/20">&middot;</span>
        <span>{readingTime} min read</span>
      </div>
      <div class="divider-gold w-24 mt-8"></div>
    </div>
  </section>

  <!-- ESSAY BODY -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-16 md:py-24 max-w-2xl">
      <div class="space-y-6 text-muted-foreground font-body leading-relaxed text-[15px]">
        {essay.paragraphs.map((paragraph: string) => (
          <p>{paragraph}</p>
        ))}
      </div>

      {essay.closingBridge && (
        <div class="mt-16">
          <div class="divider-gold w-24 mx-auto mb-10"></div>
          <p class="text-muted-foreground/70 font-body text-sm leading-relaxed text-center">
            {essay.closingBridge.text.split(/(Practices|counselling process|counselling page)/).map((part: string) => {
              const link = essay.closingBridge!.links.find((l: { text: string; href: string }) => l.text === part);
              return link
                ? <a href={link.href} class="text-primary/70 hover:text-primary transition-colors">{part}</a>
                : part;
            })}
          </p>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-16 border border-border rounded-lg p-8 md:p-10 text-center bg-muted/30">
        <h3 class="font-heading text-xl md:text-2xl text-foreground mb-4">
          Explore This Work Directly
        </h3>
        <p class="text-muted-foreground font-body text-sm leading-relaxed max-w-lg mx-auto mb-8">
          If something in this essay resonates, the next step is a conversation. One-on-one counselling, breathwork, and meditation, integrated into a single, grounded process.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-primary text-primary-foreground hover:bg-gold-light transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body"
        >
          Enquire About Working Together
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="divider-gold w-24 mx-auto mt-16"></div>

      <div class="mt-10 text-center">
        <a
          href="/wisdom"
          class="text-sm text-primary/70 hover:text-primary font-body transition-colors"
        >
          &larr; Back to all essays
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
