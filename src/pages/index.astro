---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import sanghamLogo from '../assets/sangham-logo.png';
import heroBg from '../assets/hero-bg.jpg';
import caveMeditation from '../assets/cave-meditation.jpg';
import sanghamCeremony from '../assets/sangham-ceremony.jpg';
import mistyValley from '../assets/misty-valley.jpg';
import aboveClouds from '../assets/above-clouds.jpg';
import swamiPortrait from '../assets/swami-ramarishi-portrait.jpg';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Sangham',
    url: 'https://sangham.org',
    logo: 'https://sangham.org/sangham-logo.png',
    description: 'Integrative counselling, breathwork, and inner work conducted online via video call.',
    founder: { '@type': 'Person', name: 'Michael Kaplan', alternateName: 'Swami Ramarishi' },
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'ramarishi@sangham.org',
      telephone: '+2773678063',
      contactType: 'customer service',
    },
    sameAs: ['https://instagram.com/sangham.space'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Sangham',
    url: 'https://sangham.org',
    description: 'A place for careful, grounded inner work.',
  },
];

const workCards = [
  {
    title: 'Counselling and dialogue',
    text: 'A grounded, relational process of understanding how a person actually functions, in real time, within the context of their life. Not abstract theory or performative conversation, but genuine engagement with the patterns, responses, and gaps between intention and action. This is where the work begins and where it deepens over time.',
    path: '/counselling',
  },
  {
    title: 'Practical interventions',
    text: 'Breathwork, meditation, and body-based practices used carefully and appropriately, not as fixed techniques or lifestyle habits, but as tools. The same practice can stabilise one person and unsettle another. What matters is how, when, and why it is applied. Precision here is what separates genuine support from well-meaning but misguided instruction.',
    path: '/practices',
  },
  {
    title: 'Integration into real life',
    text: 'Everything is brought back into relationships, decisions, work, and environment. Without this, insight remains theoretical. The measure of this work is not how someone feels during a session, but how they function in the days and weeks that follow. Integration is where change becomes real and sustainable.',
    path: '/counselling#integration',
  },
];

const whoItems = [
  'A clear awareness of certain patterns, alongside a frustrating inability to shift them, despite genuine effort',
  'Cycles of overthinking, reactivity, avoidance, or emotional intensity that affect relationships and sense of self',
  'An interest in meditation, breathwork, or inner work, combined with frustration at approaches that feel vague, impractical, or disconnected from daily reality',
  'Concern for a teenager or young adult who seems to be struggling with direction, identity, emotional regulation, or social pressure',
  'Experience of therapy or coaching that felt helpful but somehow incomplete, as though something more embodied or more direct was needed',
  'A readiness to engage honestly, not just to consume information, but to participate in a process that asks something real',
];

const waysCards = [
  {
    title: 'One-on-one counselling',
    text: 'The core of the process. A direct, structured engagement with patterns, responses, and lived experience. Most people begin with a structured five-session process designed to bring clarity and create movement where things feel stuck. From there, the work continues as long as it is genuinely useful.',
    path: '/counselling',
    cta: 'Explore counselling',
    highlight: true,
  },
  {
    title: 'Guided practices',
    text: 'A selection of accessible practices to help stabilise attention and regulate the body. These can serve as a starting point or as a complement to one-on-one work. They are designed to be simple enough to begin immediately and deep enough to grow with over time.',
    path: '/practices',
    cta: 'Explore practices',
    highlight: false,
  },
  {
    title: 'Workshops',
    text: 'Occasional spaces to explore aspects of the work in a shared, focused setting. These are offered from time to time and can serve as a strong entry point, particularly for those who prefer to begin in a group context before committing to individual work.',
    path: '/workshops',
    cta: 'Learn about workshops',
    highlight: false,
  },
];
---

<BaseLayout
  title="Grounded Inner Work, Counselling & Integration"
  description="Sangham offers grounded inner work through counselling, breathwork, and meditation, integrated into one coherent process. Online sessions worldwide."
  jsonLd={jsonLd}
>

  <!-- HERO -->
  <section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden -mt-[72px] pt-[72px]">
    <Image
      src={heroBg}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-30"
      widths={[640, 1024, 1536, 2048]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-sacred-gradient opacity-80"></div>

    <div class="relative z-10 text-center px-6 max-w-3xl">
      <Image
        src={sanghamLogo}
        alt="Sangham"
        class="h-20 md:h-28 w-auto mx-auto mb-10"
        width={224}
        height={224}
        loading="eager"
      />

      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl xl:text-6xl text-parchment/90 leading-tight mb-6">
        A place for careful, grounded<br />
        <span class="text-gold-light">inner work.</span>
      </h1>

      <p class="text-parchment/65 font-body text-base md:text-lg max-w-xl mx-auto mt-6 leading-relaxed">
        If you understand what tends to go wrong but still find yourself caught in it, this work is designed for that gap.
      </p>

      <p class="text-parchment/40 font-body text-sm max-w-lg mx-auto mt-4 leading-relaxed">
        A structured approach to counselling, breathwork, and body-based practice, integrated into one coherent process conducted online via video call.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/counselling"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-primary text-primary-foreground hover:bg-gold-light transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body font-medium shadow-lg shadow-primary/20"
        >
          Explore the Counselling Process
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center gap-2 px-8 py-3 text-parchment/45 hover:text-parchment/70 transition-all duration-300 text-sm tracking-wider uppercase font-body"
        >
          About the Approach
        </a>
      </div>

      <p class="mt-6 text-parchment/30 font-body text-xs tracking-wide">
        Currently accepting new clients. Initial consultation available.
      </p>
    </div>
  </section>

  <!-- WHY THIS WORK MATTERS -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-foreground text-center mb-10">
        Why This Work Matters
      </h2>

      <div class="space-y-6 text-muted-foreground font-body leading-relaxed">
        <p class="text-lg text-foreground/90">
          Inner work is often approached through ideas, techniques, or isolated effort.
        </p>
        <p>
          Insight can deepen, practices can be learned, and yet the underlying patterns of behaviour remain unchanged. It is possible to understand something clearly and still be caught in it. To see a pattern, name it accurately, and watch it repeat regardless. This is not a failure of intelligence or willpower. It reflects something about the nature of how change actually works.
        </p>
        <p>
          What is often missing is not information, but context. A way of working where understanding is tested, refined, and applied within the reality of a person's life. Where the body is included, not just the mind. Where insight is not the endpoint, but the starting point of a more practical and sustained process.
        </p>
        <div class="border border-primary/20 rounded-lg px-5 py-4 bg-primary/4 mt-2">
          <p class="text-sm text-foreground/75 font-body leading-relaxed">
            Most people begin with a structured five-session process designed to bring clarity and create movement where things feel stuck.
            <a href="/counselling" class="text-primary/70 hover:text-primary transition-colors ml-2 whitespace-nowrap">See how it works &rarr;</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- THE WORK -->
  <section class="bg-header text-header-foreground">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-4xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-6">
        The Work
      </h2>

      <p class="text-header-foreground/60 font-body leading-relaxed text-center mb-14 max-w-2xl mx-auto">
        Sangham is built around a simple structure. It combines three interconnected elements into a single, coherent process that addresses what most fragmented approaches cannot.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {workCards.map((card) => (
          <a
            href={card.path}
            class="group block border border-header-foreground/10 rounded-lg p-8 hover:border-primary/30 hover:-translate-y-[3px] hover:bg-void/40 transition-all duration-200 ease-out cursor-pointer relative"
          >
            <h3 class="font-heading text-xl text-header-foreground/90 mb-4 group-hover:text-header-foreground transition-colors">{card.title}</h3>
            <p class="text-header-foreground/55 font-body text-sm leading-relaxed">{card.text}</p>
            <span class="absolute bottom-6 right-6 text-primary/0 group-hover:text-primary/60 transition-all duration-200 text-lg">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY THIS IS DIFFERENT -->
  <section class="relative overflow-hidden">
    <Image
      src={caveMeditation}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1536]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-void/82"></div>
    <div class="relative z-10 container mx-auto px-6 py-24 md:py-32 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-10">
        Why This Is Different
      </h2>

      <div class="space-y-6 text-parchment/65 font-body leading-relaxed">
        <p class="text-parchment/80 text-lg">
          Meditation and yoga are often taught as skills to be acquired. In practice, they are something quite different.
        </p>
        <p>
          Done properly, they function as interventions into how a person perceives, regulates, and responds to life. They work at the level of the nervous system, attention, and the relationship someone has with their own experience. That kind of work cannot be learned passively, in a group class, or through an app. It requires context, feedback, and a real relationship where what is happening can be seen, adjusted, and integrated over time.
        </p>
        <p>
          What makes this work distinctive is that it does not separate the psychological from the contemplative. It treats inner life as one interconnected system: thought, emotion, body, breath, attention, and action. And it works with all of these within the context of a person's actual life, not in a vacuum.
        </p>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-foreground text-center mb-6">
        Who This Is For
      </h2>

      <p class="text-muted-foreground font-body leading-relaxed text-center mb-10">
        This work tends to be most relevant for people who have already done some reflecting but recognise that understanding alone has not been enough. It may resonate if any of the following feel familiar:
      </p>

      <ul class="space-y-4 mb-10 list-disc list-outside ml-6 text-muted-foreground font-body leading-relaxed marker:text-primary/40">
        {whoItems.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="text-center">
        <a
          href="/counselling"
          class="inline-flex items-center gap-2 text-primary/80 hover:text-primary font-body text-sm tracking-wide transition-colors"
        >
          See how the counselling process works
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- THE GUIDE -->
  <section class="relative overflow-hidden">
    <Image
      src={sanghamCeremony}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1536]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-void/88"></div>
    <div class="relative z-10 container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-12">
        The Guide
      </h2>

      <div class="flex justify-center mb-10">
        <div class="w-44 h-44 md:w-52 md:h-52 rounded-full overflow-hidden border-2 border-primary/20">
          <Image
            src={swamiPortrait}
            alt="Michael Kaplan (Swami Ramarishi)"
            class="w-full h-full object-cover"
            width={208}
            height={208}
          />
        </div>
      </div>

      <div class="space-y-6 text-parchment/65 font-body leading-relaxed">
        <p class="text-parchment/80">
          Sangham is guided by Michael Kaplan (Swami Ramarishi), a registered Wellness Counsellor whose approach has been shaped by years of sustained contemplative practice, extensive experience working with individuals and groups, and a deep engagement with the psychological dimensions of inner work. Currently based in India, Michael works with clients online via video call with people across South Africa and internationally. His professional registration is held in South Africa, and the work is offered online in a supportive counselling and wellbeing capacity.
        </p>
        <p>
          His background spans training within established contemplative traditions, process work facilitation, and years of direct engagement with people across a wide range of contexts, from adolescents navigating identity and emotional difficulty to adults working through anxiety, relational patterns, loss, and life transitions.
        </p>
        <p>
          The result is an approach that is psychologically informed, practically grounded, and responsive to the real complexity of human experience. It does not rely on a single method or tradition. It draws on what tends to work, refined through relationship and direct observation over time.
        </p>
      </div>

      <div class="text-center mt-10">
        <a
          href="/about"
          class="inline-flex items-center gap-2 text-primary/60 hover:text-primary/90 font-body text-sm tracking-wide transition-colors"
        >
          Read more about the approach and background
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- TRUST SIGNALS -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-14 md:py-16 max-w-4xl">
      <div class="border border-border/60 rounded-lg bg-muted/20 px-8 py-10 md:px-12 md:py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 mb-10">
          <!-- Credential 1 -->
          <div class="flex gap-4">
            <svg class="w-5 h-5 mt-0.5 shrink-0 text-primary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.745 3.745 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
            <div>
              <p class="font-body text-sm text-foreground/80">Wellness Counsellor, ASCHP (Reg. No. 10559)</p>
              <p class="font-body text-xs text-muted-foreground/50 mt-1 leading-relaxed">Association for Supportive Counsellors and Holistic Practitioners</p>
              <p class="font-body text-xs text-muted-foreground/40 leading-relaxed">Recognised professional body, NQF registered (South Africa)</p>
              <p class="font-body text-xs text-muted-foreground/40 leading-relaxed mt-2">Registered with the Association for Supportive Counsellors and Holistic Practitioners in South Africa. Services are offered online in a supportive counselling and wellbeing capacity and do not constitute psychology, psychiatry, medical treatment, or emergency mental health care. Where specialised or acute care is needed, referral to an appropriate locally licensed professional may be recommended.</p>
            </div>
          </div>
          <!-- Credential 2 -->
          <div class="flex gap-4">
            <svg class="w-5 h-5 mt-0.5 shrink-0 text-primary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.745 3.745 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
            <div>
              <p class="font-body text-sm text-foreground/80">300-Hour Yoga Teacher Training, Yoga Alliance (RYS 300)</p>
              <p class="font-body text-xs text-muted-foreground/50 mt-1 leading-relaxed">Hatha & Ashtanga, Triguna Yoga, Rishikesh</p>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          <!-- Fact 1 -->
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
            <p class="font-body text-xs text-muted-foreground/60">Online worldwide: video call, all timezones accommodated</p>
          </div>
          <!-- Fact 2 -->
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
            </svg>
            <p class="font-body text-xs text-muted-foreground/60">Initial consultation available, no obligation to continue</p>
          </div>
          <!-- Fact 3 -->
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
            <p class="font-body text-xs text-muted-foreground/60">Works with adults, adolescents, and those on an established inner path</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WAYS TO BEGIN -->
  <section class="bg-background border-t border-border/25">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-4xl">
      <h2 class="font-heading text-3xl md:text-4xl text-foreground text-center mb-4">
        Ways to Begin
      </h2>

      <p class="text-muted-foreground font-body leading-relaxed text-center mb-12 max-w-2xl mx-auto">
        For most people, counselling is the natural starting point. The guided practices and occasional workshops extend and support that core work. Whichever feels like the right place to begin, the commitment is the same: clarity, practical application, and honest engagement.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {waysCards.map((card) => (
          <a
            href={card.path}
            class:list={[
              'block h-full p-8 border rounded-lg transition-all duration-500 group',
              card.highlight
                ? 'border-primary/30 bg-primary/5 hover:border-primary/50'
                : 'border-border bg-card hover:border-primary/40',
            ]}
          >
            <div class="flex items-center gap-3 mb-1">
              <h3 class="font-heading text-xl text-foreground group-hover:text-primary transition-colors">
                {card.title}
              </h3>
              {card.highlight && (
                <span class="text-[10px] font-body tracking-widest uppercase px-2 py-0.5 border border-primary/25 text-primary/50 rounded-full">Primary path</span>
              )}
            </div>
            {card.highlight && (
              <p class="text-xs text-muted-foreground/50 font-body mb-3">Online via video call</p>
            )}
            {!card.highlight && <div class="mb-3"></div>}
            <p class="text-muted-foreground text-sm font-body leading-relaxed mb-3">
              {card.text}
            </p>
            {card.highlight && (
              <p class="text-xs text-primary/50 font-body mb-3">Begins with a full initial consultation, no obligation to continue.</p>
            )}
            {!card.highlight && <div class="mb-2"></div>}
            <span class="inline-flex items-center gap-1 text-primary/70 text-sm font-body tracking-wide group-hover:text-primary transition-colors">
              {card.cta}
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ENVIRONMENT AND AWARENESS -->
  <section class="relative overflow-hidden">
    <Image
      src={mistyValley}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
