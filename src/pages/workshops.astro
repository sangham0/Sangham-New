---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { Image } from 'astro:assets';
import mountainSummit from '../assets/mountain-summit.jpg';
import moonlightOcean from '../assets/moonlight-ocean.jpg';
import loneTreeSunset from '../assets/lone-tree-sunset.jpg';
import workshopMeditation from '../assets/workshop-india-meditation.jpg';
import workshopYoga from '../assets/workshop-india-yoga.jpg';
import workshopCircle from '../assets/workshop-capetown-circle.png';
import workshopCeremony from '../assets/workshop-capetown-ceremony.png';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Workshops & Small Group Sessions',
    provider: { '@type': 'Organization', name: 'Sangham' },
    serviceType: 'Workshop',
  },
];

const workshopPhotos = [
  { src: workshopMeditation, alt: 'Rooftop meditation session, Rishikesh, India', caption: 'Rooftop meditation session, Rishikesh, India' },
  { src: workshopCircle, alt: 'Workshop circle, Cape Town', caption: 'Workshop circle, Cape Town' },
  { src: workshopCeremony, alt: 'Fire ritual, Cape Town', caption: 'Fire ritual, Cape Town' },
  { src: workshopYoga, alt: 'Hatha yoga intensive, Rishikesh, India', caption: 'Hatha yoga intensive, Rishikesh, India' },
];

const workshops = [
  {
    title: "Learn to Meditate",
    subtitle: "Foundations of Stillness & Attention",
    description: "A practical introduction to meditation for those who want clarity, not mysticism.",
    covers: [
      "How to sit comfortably and sustainably",
      "Working with the breath as an anchor",
      "Understanding distraction and mental activity",
      "Building a simple, consistent practice"
    ],
    outcome: "You leave with a method you can actually continue on your own."
  },
  {
    title: "Hara Meditation",
    subtitle: "Grounding Awareness in the Body",
    description: "A meditation workshop focused on shifting awareness out of the head and into the body.",
    covers: [
      "The Hara as a centre of stability and perception",
      "Breath awareness below the navel",
      "How emotional patterns live in the body",
      "Developing grounded presence over mental control"
    ],
    outcome: "Greater stability, less overthinking, deeper embodied awareness."
  },
  {
    title: "Pranayama Foundations",
    subtitle: "Breathwork for Regulation, Not Stimulation",
    description: "A grounded introduction to traditional breath practices, taught safely and progressively.",
    covers: [
      "How breath affects the nervous system",
      "Foundational balancing practices",
      "Why most modern breathwork is overstimulating",
      "Building capacity before intensity"
    ],
    outcome: "A clear, safe way to use breath as a tool for regulation and clarity."
  },
  {
    title: "Hatha Yoga Intensive",
    subtitle: "Strength, Stillness & Awareness in the Body",
    description: "A deeper dive into physical practice beyond a standard class.",
    covers: [
      "Holding postures with awareness and precision",
      "The relationship between effort and relaxation",
      "Breath integration within movement",
      "Building strength without losing sensitivity"
    ],
    outcome: "A more intelligent relationship with your body and practice."
  },
  {
    title: "Lunar Practice",
    subtitle: "Inner Cycles & Sensitivity",
    description: "A themed workshop using the full moon as a focal point for internal awareness.",
    covers: [
      "Sensitivity to internal cycles",
      "Breath and awareness practices aligned with receptivity",
      "Reflection and release",
      "Grounded rather than mystical in approach"
    ],
    outcome: "A structured space for natural internal reset and clarity."
  },
  {
    title: "Half-Day Immersion",
    subtitle: "Integrated Practice Experience",
    description: "A longer-form session combining movement, breath, meditation, and reflection.",
    covers: [
      "Guided physical practice",
      "Breathwork",
      "Seated meditation",
      "Group integration and dialogue"
    ],
    outcome: "A deeper reset than a single class allows."
  }
];
---

<BaseLayout
  title="Workshops & Small Group Sessions"
  description="Occasional workshops and small group sessions exploring attention, breath, and regulation. Held in South Africa, India, and Europe."
  jsonLd={jsonLd}
>

  <PageHeader
    title="Workshops & Small Group Sessions"
    subtitle="Occasional spaces to explore the work in a shared, focused setting."
  />

  <!-- OPENING -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <div class="space-y-6 text-muted-foreground font-body leading-relaxed">
        <p class="text-lg text-foreground/90">
          While most of the work at Sangham unfolds through one-on-one process, there are times when a group setting can offer something that individual work cannot.
        </p>
        <p>
          Workshops and small group sessions provide a focused space to explore specific aspects of the work in a structured, intentional way. There is something uniquely valuable about practising alongside others, about witnessing and being witnessed in a carefully held environment. The shared quality of attention in a well-held group creates conditions that are difficult to replicate alone.
        </p>
        <p>
          These are not drop-in classes or casual meetups. They are crafted experiences with clear themes, purposeful structure, and enough space for both guided work and genuine reflection. The emphasis is always on what can actually be applied, not on spiritual performance or group catharsis.
        </p>
        <p>
          Workshops are offered both in person and, where appropriate, in adapted online formats. In-person sessions have been held in South Africa, India, and Europe. Where there is sufficient interest and the right conditions, workshops can be arranged in other locations. If you have a group in mind, getting in touch is the best starting point.
        </p>
        <p>
          These workshops are educational and experiential group offerings. They are not a substitute for individual psychological, psychiatric, medical, or emergency care.
        </p>
      </div>
    </div>
  </section>

  <!-- WORKSHOPS IN PRACTICE (PHOTO CAROUSEL) -->
  <section class="bg-header">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-5xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-12">
        Workshops in Practice
      </h2>

      <div class="flex gap-5 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide">
        {workshopPhotos.map((photo) => (
          <div class="flex-shrink-0 w-72 md:w-80 snap-center">
            <div class="rounded-lg overflow-hidden">
              <Image
                src={photo.src}
                alt={photo.alt}
                class="w-full h-52 md:h-60 object-cover"
                widths={[320, 640]}
                sizes="320px"
              />
            </div>
            <p class="text-xs text-header-foreground/40 font-body mt-3 text-center">{photo.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WORKSHOP TYPES -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-5xl">
      <h2 class="font-heading text-3xl md:text-4xl text-foreground text-center mb-4">
        Workshop Types
      </h2>
      <p class="text-muted-foreground font-body leading-relaxed text-center mb-14 max-w-2xl mx-auto">
        Each workshop is structured around a clear theme. These are the formats currently offered, either as scheduled sessions or on request for private groups.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {workshops.map((w) => (
          <div class="border border-border rounded-lg p-7 flex flex-col">
            <h3 class="font-heading text-lg text-foreground mb-1">{w.title}</h3>
            <p class="text-xs text-primary/50 font-body tracking-wide uppercase mb-3">{w.subtitle}</p>
            <p class="text-muted-foreground font-body text-sm leading-relaxed mb-4">{w.description}</p>
            <ul class="space-y-2 text-muted-foreground/70 font-body text-sm mb-4 list-disc list-outside ml-5 marker:text-primary/30">
              {w.covers.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <p class="text-sm text-foreground/70 font-body italic mb-6 mt-auto">{w.outcome}</p>
            <div class="flex flex-col gap-2">
              <button
                class="workshop-notify-btn w-full px-4 py-2.5 border border-primary/30 text-primary/70 hover:border-primary/60 hover:text-primary transition-all duration-300 rounded-lg text-xs tracking-wider uppercase font-body"
              >
                Notify me when this runs
              </button>
              <a
                href="/contact?enquiry=workshop-group"
                class="w-full px-4 py-2.5 text-center text-muted-foreground/50 hover:text-muted-foreground/80 transition-colors text-xs tracking-wider uppercase font-body"
              >
                Request for a group
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="relative overflow-hidden">
    <Image
      src={mountainSummit}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1536]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-void/70"></div>
    <div class="relative z-10 container mx-auto px-6 py-24 md:py-28 max-w-3xl">
      <blockquote class="border-l-2 border-primary/40 pl-8">
        <p class="font-heading text-xl md:text-2xl text-parchment/80 italic leading-relaxed">
          The work is always the same: to see more clearly and respond more honestly.
        </p>
      </blockquote>
    </div>
  </section>

  <!-- WHO THESE ARE FOR -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-12">
        Who These Are For
      </h2>

      <div class="space-y-6 text-muted-foreground font-body leading-relaxed">
        <p>
          Workshops are open to a range of participants. Prior experience with meditation, breathwork, or inner work is not required. They may be particularly relevant for those who:
        </p>

        <ul class="space-y-4 list-disc list-outside ml-6">
          <li>Are new to this kind of work and want a clear, supported introduction before committing to individual process</li>
          <li>Prefer to begin in a group setting, where the atmosphere can feel less intense than one-on-one engagement</li>
          <li>Want to explore a specific aspect of the work more directly, such as breath, attention, or regulation</li>
          <li>Are already engaged in individual counselling and want complementary group experience</li>
          <li>Are curious about Sangham and want to experience the quality of the work before enquiring further</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- NATURE AND ENVIRONMENTAL SESSIONS -->
  <section class="relative overflow-hidden">
    <Image
      src={moonlightOcean}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1536]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-void/82"></div>
    <div class="relative z-10 container mx-auto px-6 py-24 md:py-32 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-12">
        Nature and Environmental Sessions
      </h2>

      <div class="space-y-6 font-body leading-relaxed">
        <p class="text-parchment/80">
          Some aspects of this work are explored more directly in natural environments.
        </p>
        <p class="text-parchment/65">
          These sessions focus on developing sensitivity to attention, sound, rhythm, and place, and how these influence regulation and perception. The nervous system responds differently in natural settings. Patterns that are invisible in familiar environments can become more apparent when the context shifts. And certain capacities, particularly around sensory awareness, settling, and presence, can develop more readily when supported by the right surroundings.
        </p>
        <p class="text-parchment/65">
          Rather than treating nature as something separate or symbolic, the emphasis is on direct experience and practical awareness. This is not wilderness therapy or eco-spirituality. It is a grounded exploration of how environment shapes perception and how that understanding can be used to support clearer functioning in everyday life.
        </p>
        <p class="text-parchment/65">
          These sessions can offer a different context for developing clarity, stability, and a sense of connection that extends beyond internal reflection alone. They are offered occasionally and are typically open to both new and existing participants.
        </p>
      </div>
    </div>
  </section>

  <!-- STAY INFORMED & CLOSING -->
  <section class="relative overflow-hidden">
    <Image
      src={loneTreeSunset}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1536]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-void/78"></div>
    <div class="relative z-10 container mx-auto px-6 py-24 md:py-32 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-12">
        Stay Informed
      </h2>

      <div class="space-y-6 text-header-foreground/65 font-body leading-relaxed text-center">
        <p>
          Workshops are offered occasionally rather than on a fixed schedule. They are designed to be responsive to what is needed, rather than filling a calendar.
        </p>
      </div>

      <div class="border border-header-foreground/10 rounded-lg p-8 mt-10 mb-12 text-center bg-void/30">
        <div id="workshop-waitlist-container">
          <form id="workshop-waitlist-form" class="flex gap-3 max-w-sm mx-auto">
            <input type="hidden" name="_subject" value="Workshop waitlist | Sangham" />
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              class="flex-1 bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body text-sm placeholder:text-header-foreground/30 focus:outline-none focus:border-primary/40 transition-colors"
            />
            <button
              type="submit"
              class="px-6 py-3 bg-primary text-primary-foreground hover:bg-gold-light transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body whitespace-nowrap"
            >
              Notify me
            </button>
          </form>
          <p class="text-xs text-header-foreground/35 font-body mt-3">You'll only hear when something is scheduled.</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-primary text-primary-foreground hover:bg-gold-light transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body"
        >
          Enquire About Sessions
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
        <a
          href="/counselling"
          class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-header-foreground/15 text-header-foreground/60 hover:text-header-foreground/80 hover:border-header-foreground/30 transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body"
        >
          Or Explore One-on-One Work
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  // Workshop waitlist form
  const form = document.getElementById('workshop-waitlist-form') as HTMLFormElement;
  const container = document.getElementById('workshop-waitlist-container')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const response = await fetch('https://formspree.io/f/mojpzywj', {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        container.innerHTML = `<p class="font-body text-sm text-header-foreground/60">You're subscribed. Thank you.</p>`;
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      container.innerHTML = `<p class="font-body text-sm text-header-foreground/60">Something went wrong. Please try again or email <a href="mailto:ramarishi@sangham.org" class="text-primary/70 hover:text-primary transition-colors">ramarishi@sangham.org</a>.</p>`;
    }
  });

  // "Notify me when this runs" buttons scroll to the waitlist form
  document.querySelectorAll('.workshop-notify-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = document.getElementById('workshop-waitlist-container');
      el?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      const input = el?.querySelector('input[type="email"]') as HTMLInputElement;
      input?.focus();
    });
  });
</script>
