---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { essays } from '../data/essays';
import type { EssayTag } from '../data/essays';
import { practiceGuides } from '../data/practice-guides';

function getReadingTime(paragraphs: string[]): number {
  const wordCount = paragraphs.join(' ').split(/\s+/).length;
  return Math.max(1, Math.round(wordCount / 200));
}

const tagLabels: Record<EssayTag, string> = {
  meditation: 'Meditation',
  breathwork: 'Breathwork',
  body: 'Body',
  psychology: 'Psychology',
  relationships: 'Relationships',
  contemplative: 'Contemplative',
};

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Wisdom | Essays & Reflections',
    description: 'Essays and reflections on meditation, breathwork, psychology, and inner work. Written by Michael Kaplan (Swami Ramarishi) of Sangham.',
    publisher: { '@type': 'Organization', name: 'Sangham', url: 'https://sangham.org' },
  },
];
---

<BaseLayout
  title="Wisdom | Essays & Reflections"
  description="Essays and reflections on meditation, breathwork, psychology, and inner work. Written by Michael Kaplan (Swami Ramarishi) of Sangham."
  jsonLd={jsonLd}
>

  <PageHeader
    title="Wisdom"
    subtitle="Essays, reflections, and structured writing."
  />

  <!-- INTRO -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <p class="text-muted-foreground font-body leading-relaxed text-center">
        The writing here explores the territory this work moves through: attention, the body, breath, relationship, and the mechanics of genuine change. New essays are added periodically.
      </p>
    </div>
  </section>

  <!-- ESSAYS & REFLECTIONS -->
  <section class="bg-header">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-gold-gradient text-center mb-12">
        Essays &amp; Reflections
      </h2>

      <div class="space-y-4">
        {essays.map((essay) => {
          const readTime = getReadingTime(essay.paragraphs);
          return (
            <a
              href={`/wisdom/${essay.id}`}
              class="group flex items-start gap-4 px-6 py-5 rounded-lg border border-header-foreground/10 hover:border-primary/30 hover:-translate-y-[2px] bg-void/50 hover:bg-cosmos/60 transition-all duration-200 ease-out"
            >
              <svg class="w-[18px] h-[18px] mt-0.5 shrink-0 text-primary/30 group-hover:text-primary/60 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
              <div>
                <h3 class="font-heading text-lg text-header-foreground/90 group-hover:text-header-foreground transition-colors">
                  {essay.title}
                </h3>
                <p class="font-body text-xs mt-2 text-header-foreground/40 leading-relaxed line-clamp-2">
                  {essay.excerpt}
                </p>
                <div class="flex items-center gap-3 mt-3">
                  <span class="font-body text-xs text-header-foreground/30">{essay.dateLabel}</span>
                  <span class="text-header-foreground/15">&middot;</span>
                  <span class="font-body text-xs text-header-foreground/30">{readTime} min read</span>
                  {essay.tags && essay.tags.length > 0 && (
                    <span class="text-header-foreground/15">&middot;</span>
                  )}
                  {essay.tags && essay.tags.map((tag) => (
                    <span class="inline-block px-2 py-0.5 text-[10px] font-body tracking-wider uppercase rounded-full border border-primary/15 text-primary/50">
                      {tagLabels[tag]}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- PRACTICAL INSTRUCTION GUIDES -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-3xl">
      <h2 class="font-heading text-3xl md:text-4xl text-foreground text-center mb-12">
        Practical Instruction Guides
      </h2>

      <div class="space-y-4">
        {practiceGuides.map((guide) => {
          const readTime = getReadingTime(guide.paragraphs);
          return (
            <a
              href={`/wisdom/${guide.id}`}
              class="group flex items-start gap-4 px-6 py-5 rounded-lg border border-border hover:border-primary/30 hover:-translate-y-[2px] bg-muted/30 hover:bg-muted/60 transition-all duration-200 ease-out"
            >
              <svg class="w-[18px] h-[18px] mt-0.5 shrink-0 text-primary/30 group-hover:text-primary/60 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
              <div>
                <h3 class="font-heading text-lg text-foreground/90 group-hover:text-foreground transition-colors">
                  {guide.title}
                </h3>
                <p class="font-body text-xs mt-2 text-muted-foreground/70 leading-relaxed line-clamp-2">
                  {guide.excerpt}
                </p>
                <div class="flex items-center gap-3 mt-3">
                  <span class="font-body text-xs text-muted-foreground/40">{guide.dateLabel}</span>
                  <span class="text-muted-foreground/20">&middot;</span>
                  <span class="font-body text-xs text-muted-foreground/40">{readTime} min read</span>
                  {guide.tags && guide.tags.length > 0 && (
                    <span class="text-muted-foreground/20">&middot;</span>
                  )}
                  {guide.tags && guide.tags.map((tag) => (
                    <span class="inline-block px-2 py-0.5 text-[10px] font-body tracking-wider uppercase rounded-full border border-primary/15 text-primary/50">
                      {tagLabels[tag]}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CLOSING -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-20 md:py-28 max-w-2xl text-center">
      <p class="text-muted-foreground font-body leading-relaxed mb-8">
        If you want to explore this work more directly, you can enquire about working together.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-3 border border-primary/30 text-primary/70 hover:border-primary/60 hover:text-primary transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body"
      >
        Get in Touch
      </a>
    </div>
  </section>

</BaseLayout>
