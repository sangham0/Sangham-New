---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Sangham',
    description: 'Get in touch for counselling, workshops, or general enquiries.',
    mainEntity: {
      '@type': 'Organization',
      name: 'Sangham',
      email: 'ramarishi@sangham.org',
      telephone: '+27820437887',
      sameAs: ['https://instagram.com/sangham.space'],
    },
  },
];

const enquiryTypes = [
  'One-on-one counselling',
  'The five-session integrative process',
  'Ongoing work',
  'Workshop or small group requests',
];
---

<BaseLayout
  title="Contact Sangham — Begin the Conversation"
  description="Reach out to Sangham for counselling enquiries, workshop information, or to begin the process. Email, WhatsApp, or send an enquiry directly."
  jsonLd={jsonLd}
>

  <PageHeader
    title="Get in Touch"
    subtitle="Begin the conversation."
  />

  <!-- OPENING -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl">
      <div class="space-y-6 text-muted-foreground font-body leading-relaxed text-center">
        <p>
          If you are considering working together, the first step is to reach out. You are welcome to briefly share what brings you here, or simply enquire about the process.
        </p>
        <p class="text-sm text-muted-foreground/70">
          You do not need to have everything figured out before getting in touch. Clarity can develop through the conversation.
        </p>
      </div>
    </div>
  </section>

  <!-- ENQUIRY TYPES -->
  <section class="bg-header">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl">
      <h2 class="font-heading text-2xl md:text-3xl text-gold-gradient text-center mb-10">
        Enquiries are typically for:
      </h2>

      <ul class="space-y-4 max-w-md mx-auto">
        {enquiryTypes.map((item) => (
          <li class="flex items-start gap-3 text-header-foreground/65 font-body">
            <span class="text-primary/50 mt-1.5 text-xs">&#9679;</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- WHAT HAPPENS NEXT -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl">
      <h2 class="font-heading text-2xl md:text-3xl text-foreground text-center mb-10">
        What Happens Next
      </h2>

      <div class="space-y-6 text-muted-foreground font-body leading-relaxed text-center">
        <p>
          After you reach out, you will receive a response to arrange an initial consultation. This is a full session, not a brief call.
        </p>
        <p>
          It allows space to understand what you are looking for, ask questions, and get a sense of whether this approach is a good fit. There is no obligation to continue beyond this.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT DETAILS & FORM -->
  <section class="bg-header">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-xl">
      <h2 class="font-heading text-2xl md:text-3xl text-gold-gradient text-center mb-10">
        Contact
      </h2>

      <!-- Contact cards -->
      <div class="space-y-4 mb-14">
        <a
          href="mailto:ramarishi@sangham.org"
          class="flex items-center gap-4 p-5 border border-header-foreground/10 rounded-lg hover:border-primary/30 transition-all duration-300 group"
        >
          <svg class="w-5 h-5 text-primary/40 group-hover:text-primary/70 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          <div>
            <p class="text-xs text-header-foreground/40 font-body tracking-wider uppercase mb-1">Email</p>
            <p class="text-header-foreground/80 font-body">ramarishi@sangham.org</p>
          </div>
        </a>

        <a
          href="https://wa.me/27820437887"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-5 border border-header-foreground/10 rounded-lg hover:border-primary/30 transition-all duration-300 group"
        >
          <svg class="w-5 h-5 text-primary/40 group-hover:text-primary/70 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <div>
            <p class="text-xs text-header-foreground/40 font-body tracking-wider uppercase mb-1">WhatsApp</p>
            <p class="text-header-foreground/80 font-body">082 043 7887</p>
          </div>
        </a>

        <a
          href="https://instagram.com/sangham.space"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-5 border border-header-foreground/10 rounded-lg hover:border-primary/30 transition-all duration-300 group"
        >
          <svg class="w-5 h-5 text-primary/40 group-hover:text-primary/70 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
          </svg>
          <div>
            <p class="text-xs text-header-foreground/40 font-body tracking-wider uppercase mb-1">Instagram</p>
            <p class="text-header-foreground/80 font-body">@Sangham.Space</p>
          </div>
        </a>
      </div>

      <!-- Contact Form -->
      <form class="space-y-6" data-astro-reload>
        <h3 class="font-heading text-xl text-header-foreground/85 text-center mb-2">
          Send an Enquiry
        </h3>

        <div>
          <label for="name" class="block text-sm font-body text-header-foreground/50 mb-2">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            class="w-full bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body placeholder:text-header-foreground/30 focus:outline-none focus:border-primary/40 transition-colors"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-body text-header-foreground/50 mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            class="w-full bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body placeholder:text-header-foreground/30 focus:outline-none focus:border-primary/40 transition-colors"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-body text-header-foreground/50 mb-2">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            class="w-full bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body placeholder:text-header-foreground/30 focus:outline-none focus:border-primary/40 transition-colors resize-none"
            placeholder="What brings you here?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-8 py-3 bg-primary text-primary-foreground hover:bg-gold-light transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body"
        >
          Send Enquiry
        </button>
      </form>
    </div>
  </section>

  <!-- A NOTE ON FIT -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl text-center">
      <h3 class="font-heading text-xl text-foreground mb-6">
        A Note on Fit
      </h3>
      <p class="text-muted-foreground font-body leading-relaxed text-sm">
        This work is best suited to people who are open to reflection, willing to engage honestly, and interested in practical change, not just ideas. If you are unsure, you are still welcome to reach out.
      </p>
    </div>
  </section>

</BaseLayout>
