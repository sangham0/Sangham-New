---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Sangham',
    description: 'Get in touch for counselling, workshops, or general enquiries.',
    mainEntity: {
      '@type': 'Organization',
      name: 'Sangham',
      email: 'ramarishi@sangham.org',
      telephone: '+27820437887',
      sameAs: ['https://instagram.com/sangham.space'],
    },
  },
];

const enquiryTypes = [
  'One-on-one counselling',
  'The five-session integrative process',
  'Ongoing work',
  'Workshop or small group requests',
];
---

<BaseLayout
  title="Contact Sangham | Begin the Conversation"
  description="Get in touch with Sangham to enquire about one-on-one counselling, the five-session process, or upcoming workshops. Online sessions available worldwide."
  jsonLd={jsonLd}
  hideStickyBar={true}
>

  <PageHeader
    title="Get in Touch"
    subtitle="Begin the conversation."
  />

  <!-- OPENING -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl">
      <div class="space-y-6 text-muted-foreground font-body leading-relaxed text-center">
        <p>
          If you are considering working together, the first step is to reach out. You are welcome to briefly share what brings you here, or simply enquire about the process.
        </p>
        <p class="text-sm text-muted-foreground/70">
          You do not need to have everything figured out before getting in touch. Clarity can develop through the conversation.
        </p>
      </div>
    </div>
  </section>

  <!-- ENQUIRY TYPES -->
  <section class="bg-header">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl">
      <h2 class="font-heading text-2xl md:text-3xl text-gold-gradient text-center mb-10">
        Enquiries are typically for:
      </h2>

      <ul class="space-y-3 max-w-md mx-auto list-disc list-outside ml-6 text-header-foreground/65 font-body marker:text-primary/40">
        {enquiryTypes.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- WHAT HAPPENS NEXT -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl">
      <h2 class="font-heading text-2xl md:text-3xl text-foreground text-center mb-10">
        What Happens Next
      </h2>

      <div class="space-y-6 text-muted-foreground font-body leading-relaxed text-center">
        <p>
          After you reach out, you will receive a response to arrange an initial consultation. This is a full session, not a brief call.
        </p>
        <p class="text-sm text-muted-foreground/60">
          Responses are typically sent within 1–2 business days. Sessions are scheduled to accommodate your timezone.
        </p>
        <p>
          It allows space to understand what you are looking for, ask questions, and get a sense of whether this approach is a good fit. There is no obligation to continue beyond this.
        </p>
      </div>
    </div>
  </section>

  <!-- A NOTE ON FIT -->
  <section class="bg-background">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-2xl text-center">
      <h3 class="font-heading text-xl text-foreground mb-6">
        A Note on Fit
      </h3>
      <p class="text-muted-foreground font-body leading-relaxed text-sm">
        This work is best suited to people who are open to reflection, willing to engage honestly, and interested in practical change, not just ideas. If you are unsure, you are still welcome to reach out. Sessions are held online via video call, making this work accessible wherever you are in the world.
      </p>
    </div>
  </section>

  <!-- CONTACT DETAILS & FORM -->
  <section class="bg-header">
    <div class="container mx-auto px-6 py-16 md:py-20 max-w-xl">
      <h2 class="font-heading text-2xl md:text-3xl text-gold-gradient text-center mb-10">
        Contact
      </h2>

      <!-- Contact cards -->
      <div class="space-y-4 mb-14">
        <a
          href="mailto:ramarishi@sangham.org"
          class="flex items-center gap-4 p-5 border border-header-foreground/10 rounded-lg hover:border-primary/30 transition-all duration-300 group"
        >
          <svg class="w-5 h-5 text-primary/40 group-hover:text-primary/70 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          <div>
            <p class="text-xs text-header-foreground/40 font-body tracking-wider uppercase mb-1">Email</p>
            <p class="text-header-foreground/80 font-body">ramarishi@sangham.org</p>
          </div>
        </a>

        <a
          href="https://wa.me/27820437887"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-5 border border-header-foreground/10 rounded-lg hover:border-primary/30 transition-all duration-300 group"
        >
          <svg class="w-5 h-5 text-primary/40 group-hover:text-primary/70 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <div>
            <p class="text-xs text-header-foreground/40 font-body tracking-wider uppercase mb-1">WhatsApp</p>
            <p class="text-header-foreground/80 font-body">082 043 7887</p>
          </div>
        </a>

        <a
          href="https://instagram.com/sangham.space"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-5 border border-header-foreground/10 rounded-lg hover:border-primary/30 transition-all duration-300 group"
        >
          <svg class="w-5 h-5 text-primary/40 group-hover:text-primary/70 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
          </svg>
          <div>
            <p class="text-xs text-header-foreground/40 font-body tracking-wider uppercase mb-1">Instagram</p>
            <p class="text-header-foreground/80 font-body">@Sangham.Space</p>
          </div>
        </a>
      </div>

      <!-- Contact Form -->
      <div id="contact-form-container">
        <form id="contact-form" class="space-y-6">
          <h3 class="font-heading text-xl text-header-foreground/85 text-center mb-2">
            Send an Enquiry
          </h3>

          <div>
            <label for="name" class="block text-sm font-body text-header-foreground/50 mb-2">
              Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body placeholder:text-header-foreground/30 focus:outline-none focus:border-primary/40 transition-colors"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-body text-header-foreground/50 mb-2">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body placeholder:text-header-foreground/30 focus:outline-none focus:border-primary/40 transition-colors"
              placeholder="your@email.com"
            />
          </div>

          <div>
            <label for="enquiry_type" class="block text-sm font-body text-header-foreground/50 mb-2">
              What are you enquiring about?
            </label>
            <select
              id="enquiry_type"
              name="enquiry_type"
              required
              class="w-full bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body focus:outline-none focus:border-primary/40 transition-colors"
            >
              <option value="" disabled selected>Please select...</option>
              <option value="One-on-one counselling">One-on-one counselling</option>
              <option value="Five-session integrative process">Five-session integrative process</option>
              <option value="Ongoing counselling">Ongoing counselling</option>
              <option value="Workshop or group session">Workshop or group session</option>
              <option value="General enquiry">General enquiry</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-body text-header-foreground/50 mb-2">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="w-full bg-cosmos border border-header-foreground/10 rounded-lg px-4 py-3 text-header-foreground/90 font-body placeholder:text-header-foreground/30 focus:outline-none focus:border-primary/40 transition-colors resize-none"
              placeholder="What brings you here?"
            ></textarea>
          </div>

          <p class="text-xs text-header-foreground/35 font-body text-center">
            No sales pressure. No obligation beyond the first conversation.
          </p>

          <button
            id="submit-btn"
            type="submit"
            class="w-full px-8 py-3 bg-primary text-primary-foreground hover:bg-gold-light transition-all duration-300 rounded-lg text-sm tracking-wider uppercase font-body disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send Enquiry
          </button>

          <p class="text-xs text-header-foreground/35 font-body text-center">
            You'll receive a response within 1-2 business days to arrange your initial consultation.
          </p>
        </form>
      </div>

      <!-- WhatsApp alternative -->
      <div class="text-center mt-10 pt-8 border-t border-header-foreground/10">
        <p class="text-sm text-header-foreground/50 font-body mb-4">
          Prefer to message directly?
        </p>
        <a
          href="https://wa.me/27820437887"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 px-8 py-3 rounded-lg text-sm font-body font-medium text-white transition-all duration-300 hover:scale-105"
          style="background-color: #25D366;"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </section>


</BaseLayout>

<script>
  // Pre-select enquiry type from query param
  const params = new URLSearchParams(window.location.search);
  if (params.get('enquiry') === 'workshop-group') {
    const select = document.getElementById('enquiry_type') as HTMLSelectElement;
    if (select) select.value = 'Workshop or group session';
  }

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const container = document.getElementById('contact-form-container')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const data = new FormData(form);

    try {
      const response = await fetch('https://formspree.io/f/mojpzywj', {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        container.innerHTML = `
          <div class="text-center py-8">
            <h3 class="font-heading text-xl text-header-foreground/85 mb-4">Thank you</h3>
            <p class="text-header-foreground/60 font-body leading-relaxed">
              Thank you for reaching out. You will receive a response within 2 working days.
            </p>
          </div>
        `;
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      container.innerHTML = `
        <div class="text-center py-8">
          <h3 class="font-heading text-xl text-header-foreground/85 mb-4">Something went wrong</h3>
          <p class="text-header-foreground/60 font-body leading-relaxed">
            Something went wrong. Please email
            <a href="mailto:ramarishi@sangham.org" class="text-primary/70 hover:text-primary transition-colors">ramarishi@sangham.org</a>
            directly.
          </p>
        </div>
      `;
    }
  });
</script>
