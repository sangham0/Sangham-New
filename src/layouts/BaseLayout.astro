---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description = 'Sangham offers integrative counselling, breathwork, and inner work online via video call. A place for careful, honest inner work.',
  image = '/images/og-default.jpg',
  canonicalURL = Astro.url.href,
  type = 'website',
  publishedDate,
  jsonLd,
} = Astro.props;

const siteName = 'Sangham';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Sangham',
  description: 'Integrative counselling, breathwork, and inner work conducted online via video call.',
  founder: {
    '@type': 'Person',
    name: 'Michael Kaplan',
    alternateName: 'Swami Ramarishi',
    nationality: 'South African',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Worldwide',
  },
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceType: 'Online via video call',
  },
  url: 'https://sangham.org',
  sameAs: ['https://instagram.com/sangham.space'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    {publishedDate && (
      <meta property="article:published_time" content={publishedDate} />
    )}

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
    {jsonLd?.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Analytics (production only) -->
    {import.meta.env.PROD && (
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-YZ6ZQCWJDY" is:inline></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-YZ6ZQCWJDY');
      </script>
    )}

    <slot name="head" />
  </head>
  <body>
    <Navigation />
    <main class="pt-[72px]">
      <slot />
    </main>
    <Footer />

    <!-- WhatsApp floating button — mobile only -->
    <a
      href="https://wa.me/27820437887"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 flex items-center gap-2 px-4 py-3 rounded-full shadow-lg transition-all duration-300 hover:scale-105 md:hidden"
      style="background-color: #25D366;"
      aria-label="Chat on WhatsApp"
    >
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="text-white text-sm font-body font-medium">Chat on WhatsApp</span>
    </a>
  </body>
</html>
